# Django Settings
SECRET_KEY=your-django-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Firebase Configuration
# Get these values from your Firebase project settings
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
FIREBASE_APP_ID=your-firebase-app-id

# Firebase Service Account Key (path to JSON file or JSON string)
# Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_KEY=/path/to/serviceAccountKey.json

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# Database (legacy - kept for Django ORM compatibility)
# NOTE: These are no longer used if using Firebase
DB_HOST=localhost
DB_NAME=hms_db
DB_USER=hms_user
DB_PASSWORD=hms_password
DB_PORT=5432
